#!/bin/sh
# pre-commit hook：提交前校验卡片与 Buffer 一致性

PROJECT_ROOT="$(git rev-parse --show-toplevel)"

# 要运行的校验脚本，按顺序执行
VALIDATE_CARDS="$PROJECT_ROOT/scripts/validate_cards.py"
VALIDATE_BUFFER="$PROJECT_ROOT/scripts/validate_buffer.py"

try_python() {
    interpreter="$1"
    if ! command -v "$interpreter" >/dev/null 2>&1; then
        return 1
    fi
    # 先测试解释器是否真实可用（绕过 Windows App Execution Alias）
    if ! "$interpreter" -c "import sys; sys.exit(0)" >/dev/null 2>&1; then
        return 1
    fi
    return 0
}

find_python() {
    # 优先尝试常见命令
    for cmd in python3 python py; do
        if try_python "$cmd"; then
            echo "$cmd"
            return 0
        fi
    done
    # Windows 常见安装路径兜底
    WIN_PYTHON="/c/Users/MECHREVO/AppData/Local/Programs/Python/Python313/python.exe"
    if [ -x "$WIN_PYTHON" ]; then
        echo "$WIN_PYTHON"
        return 0
    fi
    return 1
}

PYTHONInterpreter=$(find_python)
if [ -z "$PYTHONInterpreter" ]; then
    echo "错误：未找到可用的 Python 解释器，无法运行校验脚本。"
    echo "请修改 hooks/pre-commit 中的 Python 路径，或确保 python3/python/py 在 PATH 中。"
    exit 1
fi

# 运行卡片校验
"$PYTHONInterpreter" "$VALIDATE_CARDS"
CARDS_STATUS=$?
if [ $CARDS_STATUS -ne 0 ]; then
    echo ""
    echo "卡片校验失败，提交已阻止。"
    exit $CARDS_STATUS
fi

# 运行 Buffer 校验
"$PYTHONInterpreter" "$VALIDATE_BUFFER"
BUFFER_STATUS=$?
if [ $BUFFER_STATUS -ne 0 ]; then
    echo ""
    echo "Buffer 校验失败，提交已阻止。"
    exit $BUFFER_STATUS
fi

exit 0
